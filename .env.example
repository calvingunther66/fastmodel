# Copy to .env and fill in. Used by docker-compose.yml. Do NOT commit .env.

# --- App login (shared) ---
APP_USERNAME=you
APP_PASSWORD=change-me-to-something-strong

# Fixed signing key so logins survive restarts. Generate one with:
#   python3 -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=replace-with-a-fixed-hex-key

# --- Public URL (used in the .ics calendar links) ---
PUBLIC_BASE_URL=https://scheduler.calvingunther.com
TIMEZONE=America/Los_Angeles

# --- Cloudflare tunnel token ---
# From Zero Trust dashboard -> Networks -> Tunnels -> your tunnel -> install token
# (the long "eyJ..." string). See DOCKER.md.
TUNNEL_TOKEN=eyJh...your-tunnel-token...
